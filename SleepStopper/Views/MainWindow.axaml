<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SleepStopper.ViewModels"
        x:Class="SleepStopper.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="No Sleeping"
        Width="380"
        Height="360"
        MinWidth="380"
        MinHeight="360"
        MaxWidth="480"
        MaxHeight="420"
        CanResize="True"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Button.action">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.action.inactive">
            <Setter Property="Background" Value="#3CB371"/>
        </Style>
        <Style Selector="Button.action.inactive:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2E8B57"/>
        </Style>
        <Style Selector="Button.action.active">
            <Setter Property="Background" Value="#DC143C"/>
        </Style>
        <Style Selector="Button.action.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#B22222"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="10">
        <Button Grid.Row="0"
                Classes="action"
                Classes.active="{Binding IsActive}"
                Classes.inactive="{Binding !IsActive}"
                Content="{Binding ButtonText}"
                Command="{Binding ToggleCommand}"
                HorizontalAlignment="Center"
                Margin="0,8,0,4"/>

        <Button Grid.Row="1"
                Classes="action"
                Classes.active="{Binding IsPresenceActive}"
                Classes.inactive="{Binding !IsPresenceActive}"
                Content="{Binding PresenceButtonText}"
                Command="{Binding TogglePresenceCommand}"
                IsEnabled="{Binding IsPresenceSupported}"
                HorizontalAlignment="Center"
                Margin="0,4,0,4"/>

        <TextBlock Grid.Row="2"
                   Text="{Binding PresenceStatus}"
                   HorizontalAlignment="Center"
                   FontSize="11"
                   Opacity="0.8"
                   Margin="0,2,0,2"/>

        <Button Grid.Row="3"
                Content="Settings..."
                Command="{Binding OpenSettingsCommand}"
                HorizontalAlignment="Center"
                Padding="12,4"
                Margin="0,2,0,8"/>

        <TextBox Grid.Row="4"
                 Text="{Binding LogText}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Background="#1E1E1E"
                 Foreground="White"
                 FontFamily="Consolas, Courier New, monospace"
                 FontSize="11"
                 Margin="20,5,20,10"/>
    </Grid>

    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="Toggle Sleep" Command="{Binding ToggleCommand}"/>
            <NativeMenuItem Header="Toggle Presence" Command="{Binding TogglePresenceCommand}"/>
            <NativeMenuItem Header="Settings..." Command="{Binding OpenSettingsCommand}"/>
        </NativeMenu>
    </NativeMenu.Menu>

</Window>
