<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SleepStopper.ViewModels"
        x:Class="SleepStopper.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="460"
        Height="600"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="10">

            <TextBlock Text="Presence schedule" FontWeight="Bold" FontSize="14"/>

            <CheckBox Content="Weekdays only (Mon-Fri)"
                      IsChecked="{Binding WeekdaysOnly}"/>

            <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="6">
                    <CheckBox Content="Window 1" IsChecked="{Binding Window1Enabled}" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="Auto,*,Auto,*" IsEnabled="{Binding Window1Enabled}">
                        <TextBlock Grid.Column="0" Text="Start" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TimePicker Grid.Column="1" SelectedTime="{Binding Window1Start}" ClockIdentifier="24HourClock"/>
                        <TextBlock Grid.Column="2" Text="End" VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <TimePicker Grid.Column="3" SelectedTime="{Binding Window1End}" ClockIdentifier="24HourClock"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="6">
                    <CheckBox Content="Window 2" IsChecked="{Binding Window2Enabled}" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="Auto,*,Auto,*" IsEnabled="{Binding Window2Enabled}">
                        <TextBlock Grid.Column="0" Text="Start" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TimePicker Grid.Column="1" SelectedTime="{Binding Window2Start}" ClockIdentifier="24HourClock"/>
                        <TextBlock Grid.Column="2" Text="End" VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <TimePicker Grid.Column="3" SelectedTime="{Binding Window2End}" ClockIdentifier="24HourClock"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="Behavior" FontWeight="Bold" FontSize="14" Margin="0,8,0,0"/>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Tick interval (seconds)" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Column="2"
                               Width="120"
                               Minimum="5"
                               Maximum="600"
                               Increment="5"
                               Value="{Binding IntervalSeconds}"
                               FormatString="0"/>
            </Grid>

            <CheckBox Content="Pause when screen is locked"
                      IsChecked="{Binding PauseWhenLocked}"/>

            <TextBlock Text="Startup" FontWeight="Bold" FontSize="14" Margin="0,8,0,0"/>

            <CheckBox Content="Start sleep prevention on launch"
                      IsChecked="{Binding AutoStartSleepPrevention}"/>

            <CheckBox Content="Start active presence on launch"
                      IsChecked="{Binding AutoStartPresence}"/>

            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="#DC143C"
                       FontSize="11"
                       Margin="0,8,0,0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,12,0,0">
                <Button Content="Cancel" Command="{Binding CancelCommand}" Width="90"/>
                <Button Content="Save" Command="{Binding SaveCommand}" Width="90"
                        Background="#3CB371" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
